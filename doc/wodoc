;; Declarative wodoc config for the Ocsigen tutorial (manual-only, no API).
;; tuto has no dune package: pages are .mld compiled straight by odoc (direct-mld
;; mode). Its two versions (8.0, dev) are DISTINCT manuals living in master as
;; tutos/<v>/manual/, so the per-version mld-dir + manual-menu are passed on the
;; CLI (--mld-dir / --manual-menu) rather than hardcoded here.
(project tuto)
(title Doc)
(pub /tuto)
(menu-current tuto)
(mld-package tuto)
(flat)
(hosted
  (eliom           eliom           true  Eliom)
  (ocsigen-toolkit ocsigen-toolkit true  Ot)
  (ocsigen-start   ocsigen-start   true  Os)
  (ocsigenserver   ocsigenserver   false Ocsigen))
